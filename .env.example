# --- Database ---
# Local dev (Postgres running on your Mac via Homebrew or Docker):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/startup_os"

# When you move to Supabase, replace with the connection strings from
# Project Settings -> Database -> Connection string (use the "Transaction" pooler
# for DATABASE_URL and the direct connection for DIRECT_URL):
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# --- Auth ---
NEXTAUTH_URL="http://localhost:3000"
# generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"

# --- Vault encryption (for Phase 2 Password/API Vault) ---
# generate with: openssl rand -base64 32
VAULT_ENCRYPTION_KEY="replace-with-a-random-32-byte-secret"

# --- Seed users (used once by prisma/seed.ts) ---
SEED_OWNER_EMAIL="luxlinx1111@gmail.com"
SEED_OWNER_NAME="Payton"
SEED_OWNER_PASSWORD="change-me-after-first-login"
SEED_COFOUNDER_EMAIL="dad@example.com"
SEED_COFOUNDER_NAME="Dad"
SEED_COFOUNDER_PASSWORD="change-me-after-first-login"
