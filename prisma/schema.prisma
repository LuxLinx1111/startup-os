// Startup OS — Prisma schema
// Phase 1 tables (User, Project, Task*, TimeEntry, WikiPage*, ActivityLog, Notification)
// are fully wired to the UI. Phase 2 tables exist now so future modules are additive.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Identity / Auth (NextAuth-compatible) ----------

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  passwordHash      String?
  image             String?
  role              UserRole  @default(MEMBER)
  title             String?
  skills            String[]  @default([])
  ownershipAreas    String[]  @default([])
  decisionAuthority String?
  timezone          String    @default("America/New_York")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  ownedTasks       Task[]           @relation("TaskOwner")
  taskComments     TaskComment[]
  timeEntries      TimeEntry[]
  wikiPages        WikiPage[]       @relation("WikiAuthor")
  wikiRevisions    WikiRevision[]
  notes            Note[]
  filesUploaded    FileAsset[]
  decisions        Decision[]
  risks            Risk[]
  vaultItems       VaultItem[]
  activityLogs     ActivityLog[]
  notifications    Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------- Projects ----------

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  LAUNCHED
  ARCHIVED
}

model Project {
  id               String        @id @default(cuid())
  name             String
  description      String?
  status           ProjectStatus @default(ACTIVE)
  startDate        DateTime?
  targetLaunchDate DateTime?
  budgetTotal      Decimal?      @db.Decimal(12, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tasks      Task[]
  milestones Milestone[]
  expenses   Expense[]
  budgets    Budget[]
  revenues   Revenue[]
  timeEntries TimeEntry[]

  @@map("projects")
}

// ---------- Tasks ----------

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6366f1")

  taskTags TaskTag[]

  @@map("tags")
}

model TaskTag {
  taskId String
  tagId  String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@map("task_tags")
}

model Task {
  id               String       @id @default(cuid())
  title            String
  description      String?      @db.Text
  projectId        String
  ownerId          String?
  priority         TaskPriority @default(MEDIUM)
  status           TaskStatus   @default(TODO)
  dueDate          DateTime?
  estimatedHours   Decimal?     @db.Decimal(6, 2)
  order            Int          @default(0)
  isTemplate       Boolean      @default(false)
  isRecurring      Boolean      @default(false)
  recurrenceRule   String? // e.g. "FREQ=WEEKLY;INTERVAL=1"
  parentTemplateId String?
  milestoneId      String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner     User?      @relation("TaskOwner", fields: [ownerId], references: [id])
  milestone Milestone? @relation(fields: [milestoneId], references: [id])

  tags          TaskTag[]
  checklist     ChecklistItem[]
  comments      TaskComment[]
  attachments   TaskAttachment[]
  timeEntries   TimeEntry[]
  relationsFrom TaskRelation[]  @relation("RelationFrom")
  relationsTo   TaskRelation[]  @relation("RelationTo")
  bugs          Bug[]

  @@map("tasks")
}

model ChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  label     String
  isDone    Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@map("task_comments")
}

model TaskAttachment {
  id     String @id @default(cuid())
  taskId String
  fileId String

  task Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  file FileAsset @relation(fields: [fileId], references: [id])

  @@map("task_attachments")
}

enum TaskRelationType {
  RELATED
  BLOCKS
  BLOCKED_BY
  DUPLICATES
}

model TaskRelation {
  id            String           @id @default(cuid())
  taskId        String
  relatedTaskId String
  type          TaskRelationType @default(RELATED)

  task        Task @relation("RelationFrom", fields: [taskId], references: [id], onDelete: Cascade)
  relatedTask Task @relation("RelationTo", fields: [relatedTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, relatedTaskId, type])
  @@map("task_relations")
}

// ---------- Time Tracking ----------

model TimeEntry {
  id              String    @id @default(cuid())
  userId          String
  taskId          String?
  projectId       String?
  startedAt       DateTime
  endedAt         DateTime?
  durationMinutes Int       @default(0)
  isManual        Boolean   @default(false)
  isRunning       Boolean   @default(false)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("time_entries")
}

// ---------- Milestones ----------

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  AT_RISK
  COMPLETE
}

model Milestone {
  id           String          @id @default(cuid())
  projectId    String
  name         String
  description  String?
  targetDate   DateTime?
  status       MilestoneStatus @default(NOT_STARTED)
  order        Int             @default(0)
  risks        String?
  dependencies String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("milestones")
}

// ---------- Budget (Phase 2) ----------

enum ExpenseCategory {
  SOFTWARE
  CONTRACTOR
  MARKETING
  EQUIPMENT
  LEGAL
  OTHER
}

model Expense {
  id                  String          @id @default(cuid())
  projectId           String
  category            ExpenseCategory @default(OTHER)
  name                String
  amount              Decimal         @db.Decimal(12, 2)
  isRecurring         Boolean         @default(false)
  recurrenceInterval  String?
  date                DateTime
  vendor              String?
  receiptFileId       String?
  notes               String?
  createdAt           DateTime        @default(now())

  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  receipt FileAsset? @relation(fields: [receiptFileId], references: [id])

  @@map("expenses")
}

model Budget {
  id          String   @id @default(cuid())
  projectId   String
  totalAmount Decimal  @db.Decimal(12, 2)
  periodStart DateTime
  periodEnd   DateTime

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("budgets")
}

model Revenue {
  id        String   @id @default(cuid())
  projectId String
  source    String
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime
  notes     String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("revenues")
}

// ---------- Wiki / Docs ----------

enum WikiCategory {
  MEETING_NOTES
  PRD
  BUSINESS_PLAN
  TECH_DOCS
  MARKETING
  BRANDING
  LEGAL
  SOP
  RESEARCH
  COMPETITOR
  OTHER
}

model WikiPage {
  id        String       @id @default(cuid())
  title     String
  slug      String       @unique
  content   String       @db.Text
  category  WikiCategory @default(OTHER)
  authorId  String
  isPinned  Boolean      @default(false)
  tags      String[]     @default([])
  parentId  String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  author    User           @relation("WikiAuthor", fields: [authorId], references: [id])
  parent    WikiPage?      @relation("WikiTree", fields: [parentId], references: [id])
  children  WikiPage[]     @relation("WikiTree")
  revisions WikiRevision[]

  @@map("wiki_pages")
}

model WikiRevision {
  id           String   @id @default(cuid())
  pageId       String
  content      String   @db.Text
  editedById   String
  createdAt    DateTime @default(now())

  page     WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  editedBy User     @relation(fields: [editedById], references: [id])

  @@map("wiki_revisions")
}

// ---------- Notes (Phase 2) ----------

enum NoteType {
  NOTE
  BRAINSTORM
  IDEA
  WHITEBOARD
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  type      NoteType @default(NOTE)
  isPinned  Boolean  @default(false)
  tags      String[] @default([])
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@map("notes")
}

// ---------- Files (Phase 2) ----------

enum FileCategory {
  DOCUMENT
  IMAGE
  DESIGN
  CONTRACT
  OTHER
}

model Folder {
  id       String   @id @default(cuid())
  name     String
  parentId String?

  parent   Folder?     @relation("FolderTree", fields: [parentId], references: [id])
  children Folder[]    @relation("FolderTree")
  files    FileAsset[]

  @@map("folders")
}

model FileAsset {
  id                 String       @id @default(cuid())
  name               String
  url                String
  mimeType           String
  sizeBytes          Int
  category           FileCategory @default(OTHER)
  folderId           String?
  uploadedById       String
  version            Int          @default(1)
  previousVersionId  String?
  createdAt          DateTime     @default(now())

  folder       Folder?          @relation(fields: [folderId], references: [id])
  uploadedBy   User             @relation(fields: [uploadedById], references: [id])
  taskLinks    TaskAttachment[]
  expenseLinks Expense[]
  assets       Asset[]

  @@map("file_assets")
}

// ---------- Roadmap / Bugs / Feedback (Phase 2) ----------

enum RoadmapStatus {
  IDEA
  PLANNED
  IN_PROGRESS
  SHIPPED
}

model RoadmapItem {
  id             String        @id @default(cuid())
  title          String
  description    String?
  priority       TaskPriority  @default(MEDIUM)
  targetVersion  String?
  status         RoadmapStatus @default(IDEA)
  requestedBy    String?
  votes          Int           @default(0)
  createdAt      DateTime      @default(now())

  feedbackItems FeedbackItem[]

  @@map("roadmap_items")
}

enum BugSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BugStatus {
  OPEN
  IN_PROGRESS
  FIXED
  WONT_FIX
  CANNOT_REPRODUCE
}

model Bug {
  id                 String      @id @default(cuid())
  title              String
  description        String?     @db.Text
  severity           BugSeverity @default(MEDIUM)
  status             BugStatus   @default(OPEN)
  stepsToReproduce   String?     @db.Text
  screenshotFileId   String?
  resolution         String?     @db.Text
  taskId             String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  task          Task?          @relation(fields: [taskId], references: [id])
  feedbackItems FeedbackItem[]

  @@map("bugs")
}

enum FeedbackType {
  BUG
  FEATURE_REQUEST
  PRAISE
  COMPLAINT
}

enum FeedbackStatus {
  NEW
  TRIAGED
  IN_PROGRESS
  RESOLVED
  ARCHIVED
}

model FeedbackItem {
  id                  String         @id @default(cuid())
  source              String?
  customerName        String?
  content             String         @db.Text
  sentiment           String?
  type                FeedbackType   @default(FEATURE_REQUEST)
  status              FeedbackStatus @default(NEW)
  linkedRoadmapItemId String?
  linkedBugId         String?
  createdAt           DateTime       @default(now())

  linkedRoadmapItem RoadmapItem? @relation(fields: [linkedRoadmapItemId], references: [id])
  linkedBug         Bug?         @relation(fields: [linkedBugId], references: [id])

  @@map("feedback_items")
}

// ---------- Decisions & Risks (Phase 2) ----------

enum DecisionStatus {
  PROPOSED
  DECIDED
  REVISITED
}

model Decision {
  id          String         @id @default(cuid())
  title       String
  context     String?        @db.Text
  decision    String         @db.Text
  rationale   String?        @db.Text
  outcome     String?        @db.Text
  decidedById String
  decidedAt   DateTime       @default(now())
  status      DecisionStatus @default(DECIDED)

  decidedBy User @relation(fields: [decidedById], references: [id])

  @@map("decisions")
}

enum RiskImpact {
  LOW
  MEDIUM
  HIGH
}

enum RiskStatus {
  OPEN
  MITIGATING
  CLOSED
}

model Risk {
  id             String     @id @default(cuid())
  title          String
  description    String?    @db.Text
  impact         RiskImpact @default(MEDIUM)
  likelihood     RiskImpact @default(MEDIUM)
  mitigationPlan String?    @db.Text
  ownerId        String?
  status         RiskStatus @default(OPEN)
  createdAt      DateTime   @default(now())

  owner User? @relation(fields: [ownerId], references: [id])

  @@map("risks")
}

// ---------- Marketing / Assets (Phase 2) ----------

enum MarketingType {
  SOCIAL_POST
  EMAIL
  EVENT
  PARTNERSHIP
  CONTENT
}

enum MarketingStatus {
  IDEA
  SCHEDULED
  PUBLISHED
}

model MarketingItem {
  id            String          @id @default(cuid())
  type          MarketingType   @default(SOCIAL_POST)
  title         String
  channel       String?
  scheduledDate DateTime?
  status        MarketingStatus @default(IDEA)
  content       String?         @db.Text

  @@map("marketing_items")
}

enum AssetType {
  LOGO
  COLOR
  ICON
  SCREENSHOT
  GRAPHIC
  DESIGN_FILE
}

model Asset {
  id     String    @id @default(cuid())
  name   String
  type   AssetType @default(GRAPHIC)
  fileId String?
  tags   String[]  @default([])

  file FileAsset? @relation(fields: [fileId], references: [id])

  @@map("assets")
}

// ---------- Vault (Phase 2) ----------

enum VaultCategory {
  API_KEY
  PASSWORD
  LICENSE
  SERVICE
}

model VaultItem {
  id              String        @id @default(cuid())
  name            String
  category        VaultCategory @default(API_KEY)
  encryptedValue  String        @db.Text
  notes           String?
  lastRotatedAt   DateTime?
  ownerId         String
  createdAt       DateTime      @default(now())

  owner User @relation(fields: [ownerId], references: [id])

  @@map("vault_items")
}

// ---------- Launch Checklist (Phase 2) ----------

enum ChecklistSection {
  DEV
  QA
  LEGAL
  MARKETING
  APP_STORE
  ANALYTICS
  SUPPORT
  POST_LAUNCH
}

model LaunchChecklistItem {
  id         String           @id @default(cuid())
  section    ChecklistSection @default(DEV)
  title      String
  isComplete Boolean          @default(false)
  order      Int              @default(0)

  @@map("launch_checklist_items")
}

// ---------- Meetings (Phase 2) ----------

model Meeting {
  id           String   @id @default(cuid())
  title        String
  cadence      String?
  scheduledAt  DateTime?
  notes        String?  @db.Text
  actionItems  String?  @db.Text
  createdAt    DateTime @default(now())

  @@map("meetings")
}

// ---------- Cross-cutting ----------

model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String
  entityType String
  entityId   String
  action     String
  summary    String
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@map("activity_logs")
}

model Notification {
  id               String   @id @default(cuid())
  userId           String
  type             String
  title            String
  body             String?
  isRead           Boolean  @default(false)
  relatedEntityType String?
  relatedEntityId   String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}
